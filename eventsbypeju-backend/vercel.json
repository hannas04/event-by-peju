{
  "version": 2,             
  "builds": [
    {
      "src": "server.js",    
      "use": "@vercel/node"  
    }
  ],
  "routes": [
    {
      "src": "/(.*)",        
      "dest": "server.js"
    }
  ],
  "env": {
    "EMAIL_USER": "@EMAIL_USER",
    "EMAIL_PASSWORD": "@EMAIL_PASSWORD",
    "RECEIVE_EMAIL": "@RECEIVE_EMAIL"
  }
}